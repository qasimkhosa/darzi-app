{
  "expo": {
    "name": "Darzi",
    "slug": "darzi",
    "scheme": "darzi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.darzi.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Darzi to find nearby tailor shops and save your shop location for customers."
      }
    },
    "android": {
      "package": "com.bitnyxt.darzi",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Darzi to find nearby tailor shops and save your shop location for customers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Darzi to access stitched outfit photos for Feed uploads.",
          "cameraPermission": "Allow Darzi to take stitched outfit photos for Feed uploads."
        }
      ]
    ]
  }
}
